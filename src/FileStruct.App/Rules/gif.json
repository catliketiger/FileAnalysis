{
  "ruleVersion": "1.0",
  "format": "GIF",
  "description": "GIF 图片文件结构",
  "signatures": [
    {
      "name": "GIF87a",
      "pattern": [71, 73, 70, 56, 55, 97],
      "offset": 0,
      "minFileSize": 14
    },
    {
      "name": "GIF89a",
      "pattern": [71, 73, 70, 56, 57, 97],
      "offset": 0,
      "minFileSize": 14
    }
  ],
  "structures": [
    {
      "name": "GIF Header",
      "type": "struct",
      "fields": [
        { "name": "Signature", "type": "ascii", "offset": 0, "length": 3 },
        { "name": "Version", "type": "ascii", "offset": 3, "length": 3 },
        { "name": "LogicalScreenWidth", "type": "uint16", "offset": 6, "length": 2 },
        { "name": "LogicalScreenHeight", "type": "uint16", "offset": 8, "length": 2 },
        { "name": "PackedField", "type": "uint8", "offset": 10, "length": 1 },
        { "name": "BackgroundColorIndex", "type": "uint8", "offset": 11, "length": 1 },
        { "name": "PixelAspectRatio", "type": "uint8", "offset": 12, "length": 1 }
      ]
    }
  ]
}
