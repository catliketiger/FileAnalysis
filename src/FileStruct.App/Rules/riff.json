{
  "ruleVersion": "1.0",
  "format": "RIFF",
  "description": "RIFF 格式基础结构（WAV 音频 / AVI 视频 / WEBP 图片共用此容器格式）",
  "signatures": [
    {
      "name": "RIFF Container",
      "pattern": [82, 73, 70, 70],
      "offset": 0,
      "minFileSize": 12
    }
  ],
  "structures": [
    {
      "name": "RIFF Header",
      "type": "struct",
      "fields": [
        { "name": "ChunkID", "type": "ascii", "offset": 0, "length": 4 },
        { "name": "ChunkSize", "type": "uint32", "offset": 4, "length": 4 },
        { "name": "Format", "type": "ascii", "offset": 8, "length": 4 }
      ]
    },
    {
      "name": "WAVE fmt Chunk",
      "type": "struct",
      "fields": [
        { "name": "SubChunk1ID", "type": "ascii", "offset": 12, "length": 4 },
        { "name": "SubChunk1Size", "type": "uint32", "offset": 16, "length": 4 },
        { "name": "AudioFormat", "type": "uint16", "offset": 20, "length": 2 },
        { "name": "NumChannels", "type": "uint16", "offset": 22, "length": 2 },
        { "name": "SampleRate", "type": "uint32", "offset": 24, "length": 4 },
        { "name": "ByteRate", "type": "uint32", "offset": 28, "length": 4 },
        { "name": "BlockAlign", "type": "uint16", "offset": 32, "length": 2 },
        { "name": "BitsPerSample", "type": "uint16", "offset": 34, "length": 2 }
      ]
    }
  ]
}
