{
  "ruleVersion": "1.0",
  "format": "GZip",
  "description": "GZip 压缩文件结构",
  "signatures": [
    {
      "name": "GZip Magic",
      "pattern": [31, 139, 8],
      "offset": 0,
      "minFileSize": 18
    }
  ],
  "structures": [
    {
      "name": "GZip Header",
      "type": "struct",
      "fields": [
        { "name": "ID1", "type": "uint8", "offset": 0, "length": 1 },
        { "name": "ID2", "type": "uint8", "offset": 1, "length": 1 },
        { "name": "CM", "type": "uint8", "offset": 2, "length": 1 },
        { "name": "FLG", "type": "uint8", "offset": 3, "length": 1 },
        { "name": "MTIME", "type": "uint32", "offset": 4, "length": 4 },
        { "name": "XFL", "type": "uint8", "offset": 8, "length": 1 },
        { "name": "OS", "type": "uint8", "offset": 9, "length": 1 }
      ]
    },
    {
      "name": "GZip Trailer",
      "type": "struct",
      "fields": [
        { "name": "CRC32", "type": "uint32", "offset": -8, "length": 4 },
        { "name": "ISIZE", "type": "uint32", "offset": -4, "length": 4 }
      ]
    }
  ]
}
