{
  "ruleVersion": "1.0",
  "format": "LNK",
  "description": "Windows 快捷方式文件结构 (Shell Link Binary Format)",
  "signatures": [
    {
      "name": "LNK CLSID",
      "pattern": [76, 0, 0, 0, 1, 20, 2, 0, 0, 0, 0, 0, 192, 0, 0, 0, 0, 0, 0, 70],
      "offset": 0,
      "minFileSize": 76
    }
  ],
  "structures": [
    {
      "name": "Shell Link Header",
      "type": "struct",
      "fields": [
        { "name": "HeaderSize", "type": "uint32", "offset": 0, "length": 4 },
        { "name": "LinkCLSID", "type": "bytes", "offset": 4, "length": 16 },
        { "name": "LinkFlags", "type": "uint32", "offset": 20, "length": 4 },
        { "name": "FileAttributes", "type": "uint32", "offset": 24, "length": 4 },
        { "name": "CreationTime", "type": "uint64", "offset": 28, "length": 8 },
        { "name": "AccessTime", "type": "uint64", "offset": 36, "length": 8 },
        { "name": "WriteTime", "type": "uint64", "offset": 44, "length": 8 },
        { "name": "FileSize", "type": "uint32", "offset": 52, "length": 4 },
        { "name": "IconIndex", "type": "int32", "offset": 56, "length": 4 },
        { "name": "ShowCommand", "type": "uint32", "offset": 60, "length": 4 },
        { "name": "Hotkey", "type": "uint16", "offset": 64, "length": 2 },
        { "name": "Reserved1", "type": "uint16", "offset": 66, "length": 2 },
        { "name": "Reserved2", "type": "uint32", "offset": 68, "length": 4 },
        { "name": "Reserved3", "type": "uint32", "offset": 72, "length": 4 }
      ]
    }
  ]
}
