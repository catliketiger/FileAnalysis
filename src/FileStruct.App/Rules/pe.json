{
  "ruleVersion": "1.0",
  "format": "PE",
  "description": "Windows PE 可执行文件结构（简化，仅定长头部区域）",
  "signatures": [
    {
      "name": "MZ DOS Header",
      "pattern": [77, 90],
      "offset": 0,
      "minFileSize": 64
    }
  ],
  "structures": [
    {
      "name": "DOS Header",
      "type": "struct",
      "fields": [
        { "name": "e_magic", "type": "uint16", "offset": 0, "length": 2 },
        { "name": "e_cblp", "type": "uint16", "offset": 2, "length": 2 },
        { "name": "e_cp", "type": "uint16", "offset": 4, "length": 2 },
        { "name": "e_crlc", "type": "uint16", "offset": 6, "length": 2 },
        { "name": "e_cparhdr", "type": "uint16", "offset": 8, "length": 2 },
        { "name": "e_minalloc", "type": "uint16", "offset": 10, "length": 2 },
        { "name": "e_maxalloc", "type": "uint16", "offset": 12, "length": 2 },
        { "name": "e_ss", "type": "uint16", "offset": 14, "length": 2 },
        { "name": "e_sp", "type": "uint16", "offset": 16, "length": 2 },
        { "name": "e_csum", "type": "uint16", "offset": 18, "length": 2 },
        { "name": "e_ip", "type": "uint16", "offset": 20, "length": 2 },
        { "name": "e_cs", "type": "uint16", "offset": 22, "length": 2 },
        { "name": "e_lfarlc", "type": "uint16", "offset": 24, "length": 2 },
        { "name": "e_ovno", "type": "uint16", "offset": 26, "length": 2 },
        { "name": "e_oemid", "type": "uint16", "offset": 28, "length": 2 },
        { "name": "e_oeminfo", "type": "uint16", "offset": 30, "length": 2 },
        { "name": "e_reserved", "type": "bytes", "offset": 32, "length": 28 },
        { "name": "e_lfanew", "type": "uint32", "offset": 60, "length": 4 }
      ]
    },
    {
      "name": "PE Signature",
      "type": "struct",
      "fields": [
        { "name": "PESignature", "type": "bytes", "offset": 0, "length": 4 }
      ]
    },
    {
      "name": "COFF File Header",
      "type": "struct",
      "fields": [
        { "name": "Machine", "type": "uint16", "offset": 4, "length": 2 },
        { "name": "NumberOfSections", "type": "uint16", "offset": 6, "length": 2 },
        { "name": "TimeDateStamp", "type": "uint32", "offset": 8, "length": 4 },
        { "name": "PointerToSymbolTable", "type": "uint32", "offset": 12, "length": 4 },
        { "name": "NumberOfSymbols", "type": "uint32", "offset": 16, "length": 4 },
        { "name": "SizeOfOptionalHeader", "type": "uint16", "offset": 20, "length": 2 },
        { "name": "Characteristics", "type": "uint16", "offset": 22, "length": 2 }
      ]
    }
  ]
}
