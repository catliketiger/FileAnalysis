{
  "Debug": {
    "Enabled": true,
    "LogLevel": "Debug",
    "LogFile": "logs/file-struct-.log",
    "LogFileRetentionDays": 7
  },
  "FileDefaults": {
    "MaxFileSize": 209715200,
    "DefaultEncoding": "UTF-8",
    "DefaultByteGroupSize": 2,
    "DefaultEndianness": "LittleEndian"
  },
  "UI": {
    "Theme": "Light",
    "WindowWidth": 1400,
    "WindowHeight": 900,
    "FontFamily": "Cascadia Code",
    "FontSize": 13
  },
  "Recognition": {
    "AsyncThreshold": 10485760,
    "MaxHeuristicScanBytes": 67108864
  }
}
