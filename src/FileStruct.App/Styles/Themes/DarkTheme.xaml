<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 深色主题颜色资源 ===== -->

    <!-- 窗口/背景 -->
    <Color x:Key="WindowBackgroundColor">#1E1E1E</Color>
    <Color x:Key="PanelHeaderBackgroundColor">#2D2D2D</Color>
    <Color x:Key="PanelBackgroundColor">#252525</Color>
    <Color x:Key="ContentBackgroundColor">#1E1E1E</Color>

    <!-- 边框/分隔线 -->
    <Color x:Key="BorderColor">#3E3E3E</Color>
    <Color x:Key="SeparatorColor">#3E3E3E</Color>

    <!-- 文字颜色 -->
    <Color x:Key="TextPrimaryColor">#E0E0E0</Color>
    <Color x:Key="TextSecondaryColor">#9E9E9E</Color>
    <Color x:Key="TextMutedColor">#707070</Color>

    <!-- 强调色 -->
    <Color x:Key="AccentColor">#64B5F6</Color>
    <Color x:Key="AccentLightColor">#1A3A5C</Color>

    <!-- 状态颜色 -->
    <Color x:Key="ErrorColor">#EF5350</Color>
    <Color x:Key="WarningColor">#FFA726</Color>
    <Color x:Key="SuccessColor">#66BB6A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelHeaderBackgroundBrush" Color="{StaticResource PanelHeaderBackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource ContentBackgroundColor}"/>

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>

    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
</ResourceDictionary>
