<UserControl x:Class="FileStruct.App.Views.HexEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:FileStruct.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Label Content="分组:" VerticalAlignment="Center"/>
            <ComboBox Width="60" VerticalAlignment="Center" Margin="4,0"
                      SelectedIndex="1"
                      SelectionChanged="GroupSizeCombo_SelectionChanged">
                <ComboBoxItem Tag="1">1</ComboBoxItem>
                <ComboBoxItem Tag="2" IsSelected="True">2</ComboBoxItem>
                <ComboBoxItem Tag="4">4</ComboBoxItem>
                <ComboBoxItem Tag="8">8</ComboBoxItem>
            </ComboBox>
            <Separator Width="1" Background="{DynamicResource SeparatorBrush}" Margin="8,4"/>
            <CheckBox Content="小端" VerticalAlignment="Center"
                      IsChecked="{Binding HexEditor.IsLittleEndian}"/>
        </StackPanel>

        <!-- 十六进制视图 -->
        <controls:HexView Grid.Row="1"
                          x:Name="HexViewControl"
                          Buffer="{Binding HexEditor.Buffer}"
                          ByteGroupSize="{Binding HexEditor.ByteGroupSize}"
                          ScrollOffset="{Binding HexEditor.ScrollOffset}"
                          NavigateToOffset="{Binding HexEditor.NavigateToOffset}"
                          NavigateToLength="{Binding HexEditor.NavigateToLength}"/>
    </Grid>
</UserControl>
