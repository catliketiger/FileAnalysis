<UserControl x:Class="FileStruct.App.Views.HexEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:FileStruct.App.Controls"
             xmlns:converters="clr-namespace:FileStruct.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Label Content="分组:" VerticalAlignment="Center"/>
            <ComboBox x:Name="GroupSizeCombo" SelectedIndex="1" Width="60"
                      VerticalAlignment="Center" Margin="4,0">
                <ComboBoxItem Tag="1">1</ComboBoxItem>
                <ComboBoxItem Tag="2" IsSelected="True">2</ComboBoxItem>
                <ComboBoxItem Tag="4">4</ComboBoxItem>
                <ComboBoxItem Tag="8">8</ComboBoxItem>
            </ComboBox>
            <Separator Width="1" Background="#CCC" Margin="8,4"/>
            <CheckBox x:Name="EndianCheck" Content="小端" IsChecked="True"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 十六进制视图容器 -->
        <ScrollViewer Grid.Row="1" x:Name="HexScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="White">
            <controls:HexView x:Name="HexViewControl"
                              Width="1200"
                              Height="Auto"/>
        </ScrollViewer>
    </Grid>
</UserControl>
