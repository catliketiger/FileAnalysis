<Window x:Class="FileStruct.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="420" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 应用名 -->
        <TextBlock Grid.Row="0" Text="FileStruct 设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- 标签页内容 -->
        <TabControl Grid.Row="1" Margin="0,0,0,12">
            <!-- 通用标签页 -->
            <TabItem Header="通用">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <GroupBox Header="主题" Margin="0,0,0,8" Padding="8">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                                          Content="深色模式" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Label Content="强调色:" Width="80"/>
                                    <TextBox Text="{Binding AccentColor, Mode=TwoWay}"
                                             Width="100" FontFamily="Consolas"/>
                                    <TextBlock Text="例如 #1976D2" Margin="8,0,0,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="字体" Padding="8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Label Content="字体:" Width="80"/>
                                    <ComboBox Text="{Binding FontFamily, Mode=TwoWay}"
                                              Width="160" IsEditable="True">
                                        <ComboBoxItem>Cascadia Code</ComboBoxItem>
                                        <ComboBoxItem>Consolas</ComboBoxItem>
                                        <ComboBoxItem>Fira Code</ComboBoxItem>
                                        <ComboBoxItem>JetBrains Mono</ComboBoxItem>
                                        <ComboBoxItem>Source Code Pro</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="字号:" Width="80"/>
                                    <ComboBox Text="{Binding FontSize, Mode=TwoWay}"
                                              Width="80" IsEditable="True">
                                        <ComboBoxItem>10</ComboBoxItem>
                                        <ComboBoxItem>11</ComboBoxItem>
                                        <ComboBoxItem>12</ComboBoxItem>
                                        <ComboBoxItem>13</ComboBoxItem>
                                        <ComboBoxItem>14</ComboBoxItem>
                                        <ComboBoxItem>15</ComboBoxItem>
                                        <ComboBoxItem>16</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 显示标签页 -->
            <TabItem Header="显示">
                <StackPanel Margin="8">
                    <GroupBox Header="默认显示" Padding="8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Label Content="字节分组:" Width="100"/>
                                <ComboBox SelectedValue="{Binding ByteGroupSize, Mode=TwoWay}"
                                          SelectedValuePath="Tag" Width="100">
                                    <ComboBoxItem Tag="1">1</ComboBoxItem>
                                    <ComboBoxItem Tag="2">2</ComboBoxItem>
                                    <ComboBoxItem Tag="4">4</ComboBoxItem>
                                    <ComboBoxItem Tag="8">8</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Label Content="默认字节序:" Width="100"/>
                                <ComboBox SelectedValue="{Binding Endianness, Mode=TwoWay}"
                                          SelectedValuePath="Tag" Width="120">
                                    <ComboBoxItem Tag="LittleEndian">小端 (LE)</ComboBoxItem>
                                    <ComboBoxItem Tag="BigEndian">大端 (BE)</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="默认解码:" Width="100"/>
                                <ComboBox SelectedValue="{Binding DefaultDecodeType, Mode=TwoWay}"
                                          SelectedValuePath="Tag" Width="120">
                                    <ComboBoxItem Tag="Auto">自动</ComboBoxItem>
                                    <ComboBoxItem Tag="Hex">十六进制</ComboBoxItem>
                                    <ComboBoxItem Tag="Integer">整数</ComboBoxItem>
                                    <ComboBoxItem Tag="Float">浮点数</ComboBoxItem>
                                    <ComboBoxItem Tag="String">字符串</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- 规则标签页（占位，阶段2实现） -->
            <TabItem Header="规则" IsEnabled="False">
                <TextBlock Text="规则管理将在 V1.5 后续版本中实现"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="恢复默认" Width="90" Height="28"
                    Command="{Binding ResetDefaultsCommand}"/>
            <Button Grid.Column="2" Content="应用" Width="70" Height="28"
                    Command="{Binding ApplyCommand}"/>
            <Button Grid.Column="4" Content="确定" Width="70" Height="28"
                    Command="{Binding OkCommand}" IsDefault="True"/>
            <Button Grid.Column="6" Content="取消" Width="70" Height="28"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
