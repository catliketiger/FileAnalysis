<Window x:Class="FileStruct.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <GroupBox Header="显示设置" Margin="0,0,0,8">
            <StackPanel>
                <CheckBox x:Name="DarkModeCheck" Content="深色模式" Margin="4"/>
                <StackPanel Orientation="Horizontal" Margin="4">
                    <Label Content="默认分组: " Width="100"/>
                    <ComboBox x:Name="GroupSizeCombo" SelectedIndex="1" Width="80">
                        <ComboBoxItem Tag="1">1</ComboBoxItem>
                        <ComboBoxItem Tag="2">2</ComboBoxItem>
                        <ComboBoxItem Tag="4">4</ComboBoxItem>
                        <ComboBoxItem Tag="8">8</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="默认字节序" Margin="0,0,0,8">
            <ComboBox x:Name="EndianCombo" SelectedIndex="0" Width="120" HorizontalAlignment="Left" Margin="4">
                <ComboBoxItem Tag="LittleEndian">小端 (LE)</ComboBoxItem>
                <ComboBoxItem Tag="BigEndian">大端 (BE)</ComboBoxItem>
            </ComboBox>
        </GroupBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="确定" Width="80" Height="28" Margin="0,0,8,0" Click="OnOk"/>
            <Button Content="取消" Width="80" Height="28" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
