<Window x:Class="FileStruct.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FileStruct.App.Views"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="500">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 菜单栏 -->
        <Menu Grid.Row="0" IsMainMenu="True">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="打开文件(_O)" InputGestureText="Ctrl+O"
                          Command="{Binding OpenFileCommand}"/>
                <Separator/>
                <MenuItem Header="保存项目(_S)" InputGestureText="Ctrl+S"
                          Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="打开项目(_P)" InputGestureText="Ctrl+P"
                          Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="关闭文件(_C)" InputGestureText="Ctrl+W"
                          Command="{Binding CloseFileCommand}"/>
                <Separator/>
                <MenuItem Header="退出(_X)" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="视图(_V)">
                <MenuItem Header="结构识别(_R)" Command="{Binding RecognizeCommand}"/>
                <Separator/>
                <MenuItem Header="十六进制视图" IsCheckable="True"/>
                <MenuItem Header="文本视图" IsCheckable="True"/>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="关于(_A)" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- 工具栏 -->
        <ToolBar Grid.Row="1" Band="1">
            <Button Content="📂 打开" Command="{Binding OpenFileCommand}"/>
            <Button Content="🔍 识别" Command="{Binding RecognizeCommand}"/>
            <Separator/>
            <Button Content="💾 保存" Command="{Binding SaveProjectCommand}"/>
        </ToolBar>

        <!-- 主内容区 - 三栏布局 -->
        <Grid Grid.Row="2" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="250" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧面板：结构树 -->
            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F5F5F5" Padding="8,4">
                        <TextBlock Text="结构树" FontWeight="Bold"/>
                    </Border>
                    <views:StructureTreeView Grid.Row="1" x:Name="StructTreeView"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          ShowsPreview="False" Background="Transparent"/>

            <!-- 中间面板：Hex/Text 选项卡 -->
            <Grid Grid.Column="2">
                <TabControl x:Name="MainTabControl" Margin="0"
                            SelectedIndex="{Binding SelectedTabIndex}">
                    <TabItem Header="十六进制视图">
                        <views:HexEditorView x:Name="HexView"/>
                    </TabItem>
                    <TabItem Header="文本视图">
                        <views:TextView x:Name="TextView"/>
                    </TabItem>
                </TabControl>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          ShowsPreview="False" Background="Transparent"/>

            <!-- 右侧面板：预览 + 工具 -->
            <Grid Grid.Column="4">
                <TabControl Margin="0,0,0,4">
                    <TabItem Header="预览">
                        <views:LivePreviewView DataContext="{Binding LivePreview}"/>
                    </TabItem>
                    <TabItem Header="转换">
                        <views:AuxToolsView DataContext="{Binding AuxTools}"/>
                    </TabItem>
                    <TabItem Header="书签">
                        <views:BookmarkBarView DataContext="{Binding BookmarkList}"/>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding FileInfoText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
