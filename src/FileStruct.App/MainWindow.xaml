<Window x:Class="FileStruct.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FileStruct.App.Views"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="{Binding WindowTitle}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="500">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 菜单栏 -->
        <Menu Grid.Row="0" IsMainMenu="True">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="打开文件(_O)" InputGestureText="Ctrl+O"
                          Command="{Binding OpenFileCommand}"/>
                <Separator/>
                <MenuItem Header="保存项目(_S)" InputGestureText="Ctrl+S"
                          Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="打开项目(_P)" InputGestureText="Ctrl+P"
                          Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="退出(_X)"/>
            </MenuItem>
            <MenuItem Header="视图(_V)">
                <MenuItem Header="十六进制视图" IsCheckable="True"
                          IsChecked="{Binding ActiveView, Converter={x:Null}}"/>
                <MenuItem Header="文本视图" IsCheckable="True"/>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="关于(_A)"/>
            </MenuItem>
        </Menu>

        <!-- 工具栏 -->
        <ToolBar Grid.Row="0" Band="1">
            <Button Content="📂 打开" Command="{Binding OpenFileCommand}"/>
            <Button Content="💾 保存" Command="{Binding SaveProjectCommand}"/>
            <Separator/>
            <Button Content="🔄 进制转换"/>
        </ToolBar>

        <!-- 主内容区 -->
        <TabControl Grid.Row="1" x:Name="MainTabControl"
                    SelectedIndex="{Binding ActiveView, Converter={x:Null}}"
                    Margin="4">
            <TabItem Header="十六进制视图">
                <views:HexEditorView x:Name="HexView"/>
            </TabItem>
            <TabItem Header="文本视图">
                <views:TextView x:Name="TextView"/>
            </TabItem>
        </TabControl>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding FileInfoText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
